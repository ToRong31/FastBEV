# Docker Compose defaults. Copy to `.env` only if you want to override them.

# FastBEV model folder under ./model
FASTBEV_MODEL_NAME=resnet18

# fp16 or int8. The TensorRT .plan files must match this choice.
FASTBEV_PRECISION=fp16

# Optional for Modal CLI in CI/headless environments.
# Required if using `docker compose --profile modal run --rm modal-deploy`.
# Do not commit real token values.
MODAL_VOLUME_NAME=fastbev-artifacts

# Must match the TensorRT engine GPU target. Current Docker builder logs CUDASM=86,
# so A10 is the safest Modal default. Do not use T4 unless you rebuild engines for sm75.
FASTBEV_MODAL_GPU=A10

# Build portable TensorRT engines for Modal A10/L40S instead of a single local GPU.
TRT_HARDWARE_COMPATIBILITY=ampere+
TRT_FORCE_REBUILD=0

# Default deploy path rebuilds native/TensorRT artifacts on Modal GPU, then deploys API.
FASTBEV_BUILD_ARTIFACTS_ON_MODAL=1
FASTBEV_MODAL_ARTIFACT_FORCE_REBUILD=1

# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
